JWT_SECRET=change-this-to-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional AI/chatbot provider key
GROQ_API_KEY=

# Optional email scheduler settings
EMAIL_PROVIDER=smtp
RESEND_API_KEY=
RESEND_API_BASE=https://api.resend.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
# Use either SMTP_PASSWORD (preferred) or SMTP_PASS (legacy compatibility)
SMTP_PASSWORD=
SMTP_USE_TLS=true
SENDER_EMAIL=
SENDER_NAME=Zero Click AI
DATABASE_URL=database/scheduler.db
# Optional. Defaults to DATABASE_URL when unset.
USER_DB_PATH=
